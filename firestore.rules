rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================
    // Users collection
    // =========================================
    match /users/{userId} {

      // --- Read: own document or admin ---
      allow read: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();

      // --- Write (user on own doc): restricted fields only ---
      allow update: if request.auth != null
        && request.auth.uid == userId
        // Block role changes — users must NEVER change their own role
        && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role)
        // Block email changes
        && (!('email' in request.resource.data) || request.resource.data.email == resource.data.email)
        // Block createdAt changes
        && (!('createdAt' in request.resource.data) || request.resource.data.createdAt == resource.data.createdAt)
        // remainingTime must be a number >= 0
        && request.resource.data.remainingTime is number
        && request.resource.data.remainingTime >= 0;

      // Users cannot create or delete their own documents
      allow create, delete: if false;

      // --- Admin: full read/write ---
      allow read, write: if isAdmin();
    }

    // Allow admins to list all users (collection-level query)
    match /users/{document=**} {
      allow list: if isAdmin();
    }

    // =========================================
    // Settings collection
    // =========================================
    match /settings/{settingId} {
      // Any authenticated user can read settings (needed for auto-reset check)
      allow read: if request.auth != null;

      // Only admins can write settings
      allow write: if isAdmin();
    }

    // =========================================
    // Helper function: check admin role
    // =========================================
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // =========================================
    // Deny all other collections by default
    // =========================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
